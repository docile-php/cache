{
    "name": "docile/cache",
    "description": "PSR-6 and PSR-16 cache package for the Docile framework",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ali Naqi Al-Musawi",
            "email": "alinaqi2000@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "psr/cache": "^3.0",
        "psr/simple-cache": "^3.0",
        "docile/foundation": "*",
        "docile/config": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Docile\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Docile\\Cache\\Tests\\": "tests/"
        }
    }
}
